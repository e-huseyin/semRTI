rm-data:RTI-40  rdf:type     dcat:Dataset , owl:NamedIndividual;
        dct:creator          rm-agent:huseyin-erdogan;
        dct:description      "Photographic RTI dataset of The Figure with a Square (F11), acquisition session RTI-40. Comprises 48 JPG and 48 RAF images captured with a custom-built portable RTI dome at Rupe Magna Rock Engraving Park, Grosio, Italy."@en;
        dct:identifier       "RTI-40";
        dct:issued           "2025-09-05"^^xsd:date;
        dct:license          <https://creativecommons.org/licenses/by/4.0/>;
        dct:spatial          rm-site:rupe-magna;
        dct:title            "RTI Dataset — F11, RTI-40, Rupe Magna"@en;
        dcat:distribution    rm-dist:RTI-40-raw , rm-dist:RTI-40-jpg;
        dcat:inSeries        rm-series:F11;
        prov:wasGeneratedBy  rm-survey:RTI-40 .

rm-ocoll:RTI-40  rdf:type  chs:ObservationCollection , owl:NamedIndividual;
        rdfs:label  "Observation Collection — F11, RTI-40, Rupe Magna"@en .

rm-survey:RTI-40  rdf:type              chs:CulturalHeritageSurvey , owl:NamedIndividual;
        rdfs:label                      "RTI Survey — The Figure with a Square (F11), Sector S, RTI-40, Rupe Magna"@en;
        chs:hasObservationCollection    rm-ocoll:RTI-40;
        chs:isSurveyOf                  rm-site:rupe-magna , rm-fig:F11;
        chs:usesEquipmentConfiguration  rm-econf:RTI-40;
        chs:usesMethod                  rm-method:rti;
        tiapit:endTime                  "2025-09-09"^^xsd:date;
        tiapit:startTime                "2025-09-05"^^xsd:date;
        core:hasAgentRole               rm-role:RTI-40-photographer .

rm-econf:RTI-40  rdf:type               chs:EquipmentConfiguration , owl:NamedIndividual;
        rdfs:label                      "Equipment Configuration — F11, RTI-40, Rupe Magna"@en;
        chs:isEquipmentConfigurationOf  rm-survey:RTI-40;
        chs:usesEquipment               rm-equip:fujifilm-xs20 , rm-equip:rti-dome;
        a-dd:hasMeasurementCollection   rm-mcoll:RTI-40 .

rm-meas:RTI-40-focal-length
        rdf:type                   a-dd:Measurement , owl:NamedIndividual;
        rdfs:label                 "Focal length — RTI-40"@en;
        muapit:hasMeasurementUnit  rm-unit:millimetre;
        muapit:value               18.7;
        a-dd:measurementType       rm-mtype:focal-length .

rm-meas:RTI-40-shutter-speed
        rdf:type                   a-dd:Measurement , owl:NamedIndividual;
        rdfs:label                 "Shutter speed — RTI-40"@en;
        muapit:hasMeasurementUnit  rm-unit:second;
        muapit:value               0.125;
        a-dd:measurementType       rm-mtype:exposure-time .

rm-meas:RTI-40-aperture
        rdf:type                   a-dd:Measurement , owl:NamedIndividual;
        rdfs:label                 "Aperture — RTI-40"@en;
        muapit:hasMeasurementUnit  rm-unit:f-stop;
        muapit:value               10.0;
        a-dd:measurementType       rm-mtype:f-number .

rm-meas:RTI-40-iso  rdf:type       a-dd:Measurement , owl:NamedIndividual;
        rdfs:label                 "ISO sensitivity — RTI-40"@en;
        muapit:hasMeasurementUnit  rm-unit:iso-sensitivity;
        muapit:value               250;
        a-dd:measurementType       rm-mtype:iso .

rm-mcoll:RTI-40  rdf:type    a-dd:MeasurementCollection , owl:NamedIndividual;
        a-dd:hasMeasurement  rm-meas:RTI-40-focal-length , rm-meas:RTI-40-shutter-speed , rm-meas:RTI-40-aperture , rm-meas:RTI-40-iso .

