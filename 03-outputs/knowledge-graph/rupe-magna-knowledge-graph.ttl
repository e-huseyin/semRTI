rm-equip:fujifilm-xs20 a chs:Hardware,
        owl:NamedIndividual ;
    rdfs:label "Fujifilm X-S20 Mirrorless Camera"@en ;
    dct:description "APS-C mirrorless camera body. Used with Fujifilm XF 16–55 mm f/2.8 R LM WR lens. Operated in manual exposure mode throughout all RTI acquisition sessions. Images processed with darktable 5.4.1 and exported as linear JPEG."@en ;
    schema:brand "Fujifilm" ;
    schema:model "X-S20" .

rm-equip:rti-dome a chs:Hardware,
        owl:NamedIndividual ;
    rdfs:label "Custom-Built Portable RTI Dome"@en ;
    dct:description "Portable hemispherical RTI dome designed and built by Hüseyin Erdoğan (2021, revised 2024). Aluminium shell, 48-LED array across 6 elevation tiers (8 LEDs per tier, angular coverage ~9°–60°). Powered by a 5V portable power bank. Deployed at Rupe Magna in September 2025."@en ;
    dct:type "RTI Dome" ;
    schema:numberOfItems 48 ;
    schema:width "460 mm" .

