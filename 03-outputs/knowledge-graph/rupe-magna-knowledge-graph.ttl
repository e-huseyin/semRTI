rm-project:rupe-magna-rti a chs:CulturalHeritageProject,
        owl:NamedIndividual ;
    rdfs:label "Rupe Magna RTI Survey Project"@en ;
    dct:creator rm-agent:huseyin-erdogan ;
    dct:description "RTI photographic survey project documenting the rock art engravings at Rupe Magna (Grosio, Lombardy, Italy). Conducted September 2025 by Hüseyin Erdoğan (Università di Bologna). 40 acquisition sessions across 11 rock art figures using a custom-built portable RTI dome."@en ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    chs:hasSurvey rm-survey:RTI-08,
        rm-survey:RTI-17 .

