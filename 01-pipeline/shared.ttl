##############################################################################
# shared.ttl
# Rupe Magna RTI Knowledge Graph — ODP-aligned version (semRTI-ODP)
# Static shared base — the unchanging part of the graph (same across all 40 datasets)
#
# ODP structure followed (CulturalHeritageSurvey.ttl):
#   chs:CulturalHeritageProject
#     └─ chs:hasSurvey ──► chs:CulturalHeritageSurvey  [added by construct-dataset]
#           ├─ chs:isSurveyOn ──► arco:ArchaeologicalProperty
#           ├─ chs:usesEquipmentConfiguration ──► chs:EquipmentConfiguration
#           └─ chs:hasObservationCollection ──► chs:ObservationCollection
#
# Part 1: Project, Site, Agent, Equipment, MeasurementType, MeasurementUnit
# Part 2: 11 Figures (F01–F11), 11 DatasetSeries
#
# Loaded as the static base by semRTI.py and merged in memory (rdflib) with the
# dataset / photo / RTI provenance triples — written once, never concatenated.
##############################################################################

@prefix chs:     <http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix geo:     <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix a-cd:    <https://w3id.org/arco/ontology/context-description/> .
@prefix a-dd:    <https://w3id.org/arco/ontology/denotative-description/> .
@prefix arco:    <https://w3id.org/arco/ontology/arco/> .
@prefix core:    <https://w3id.org/arco/ontology/core/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix muapit:  <http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#> .
@prefix roapit:  <http://www.ontologydesignpatterns.org/ont/ro/roapit.owl#> .
@prefix schema:  <https://schema.org/> .
@prefix tiapit:  <http://www.ontologydesignpatterns.org/ont/ti/tiapit.owl#> .

@prefix rm-fig:     <https://w3id.org/rupemagna/resource/figure/> .
@prefix rm-data:    <https://w3id.org/rupemagna/resource/dataset/> .
@prefix rm-meas:    <https://w3id.org/rupemagna/resource/measurement/> .
@prefix rm-role:    <https://w3id.org/rupemagna/resource/role/> .
@prefix rm-site:    <https://w3id.org/rupemagna/resource/site/> .
@prefix rm-unit:    <https://w3id.org/rupemagna/resource/unit/> .
@prefix rm-agent:   <https://w3id.org/rupemagna/resource/agent/> .
@prefix rm-econf:   <https://w3id.org/rupemagna/resource/equipment-config/> .
@prefix rm-equip:   <https://w3id.org/rupemagna/resource/equipment/> .
@prefix rm-mcoll:   <https://w3id.org/rupemagna/resource/measurement-collection/> .
@prefix rm-mtype:   <https://w3id.org/rupemagna/resource/measurement-type/> .
@prefix rm-ocoll:   <https://w3id.org/rupemagna/resource/observation-collection/> .
@prefix rm-obs:     <https://w3id.org/rupemagna/resource/observation/> .
@prefix rm-photo:   <https://w3id.org/rupemagna/resource/photo/> .
@prefix rm-dist:    <https://w3id.org/rupemagna/resource/distribution/> .
@prefix rm-series:  <https://w3id.org/rupemagna/resource/dataset-series/> .
@prefix rm-survey:  <https://w3id.org/rupemagna/resource/survey/> .
@prefix rm-project: <https://w3id.org/rupemagna/resource/project/> .
@prefix rm-method:  <https://w3id.org/rupemagna/resource/method/> .

@base <https://w3id.org/rupemagna/ontology/shared#> .

# ─────────────────────────────────────────────────────────────────────────────
# TBox intentionally NOT declared here (T1/T2).
# The embedded owl:Ontology header, the class/object-property/datatype-property/
# annotation-property/datatype re-declarations and the LICENSE NamedIndividual
# were removed: the schema lives in rupemagna-rti-ontology.owl (own terms) plus
# the imported external ontologies (chs/arco/core/dcat/dct/a-dd/a-cd/muapit/…).
# The retired inverse-direction survey property was dropped too (data uses chs:isSurveyOn).
# shared.ttl carries ABox/data only; the @prefix block + @base above remain for it.
# ─────────────────────────────────────────────────────────────────────────────


##############################################################################
#    PART 1 — Resources shared across the entire project
##############################################################################

# ---------------------------------------------------------------------------
# A.1 — Cultural Heritage Project  [ODP: chs:CulturalHeritageProject]
#        Top-level container for all 40 RTI sessions at Rupe Magna.
#        chs:hasSurvey links are added per session in construct-dataset.sparql.
# ---------------------------------------------------------------------------

rm-project:rupe-magna-rti
    rdf:type owl:NamedIndividual, chs:CulturalHeritageProject ;
    dct:creator rm-agent:huseyin-erdogan ;
    dct:license <LICENSE_URL_PLACEHOLDER> ;
    dct:description "RTI photographic survey project documenting the rock art engravings at Rupe Magna (Grosio, Lombardy, Italy). Conducted September 2025 by Hüseyin Erdoğan (Università di Bologna). 40 acquisition sessions across 11 rock art figures using a custom-built portable RTI dome."@en ;
    rdfs:label "Rupe Magna RTI Survey Project"@en .


# ---------------------------------------------------------------------------
# A.2 — Archaeological site  [ODP: chs:CulturalProperty via arco:ArchaeologicalProperty]
# ---------------------------------------------------------------------------

rm-site:rupe-magna
    rdf:type owl:NamedIndividual, arco:ArchaeologicalProperty ;
    # geo (lat/long/alt) + address (locality/region/country) are injected at
    # build time from enrich-metadata.json (see _metadata_ttl in semRTI.py).
    dct:description "Parco delle Incisioni Rupestri di Grosio — approximately 84 × 35 metres of alpine rock art surface in Upper Valtellina, Northern Italy, featuring over 5,454 petroglyphs spanning the Bronze and Iron Ages."@en ;
    rdfs:label "Rupe Magna Rock Art Site"@en .


# ---------------------------------------------------------------------------
# A.3 — Author / Agent
# ---------------------------------------------------------------------------

rm-agent:huseyin-erdogan
    rdf:type owl:NamedIndividual, foaf:Person, core:Agent .
    # name, email (mbox), orcid, affiliation, jobTitle are injected at build time
    # from enrich-metadata.json (see _metadata_ttl in semRTI.py) — single source.


# ---------------------------------------------------------------------------
# A.4 — Equipment  [ODP: chs:Hardware, subclass of chs:Equipment]
#        Two shared instances referenced by every EquipmentConfiguration.
# ---------------------------------------------------------------------------

rm-equip:rti-dome
    rdf:type owl:NamedIndividual, chs:Hardware ;
    dct:type "RTI Dome" ;
    schema:numberOfItems 48 ;
    schema:width "460 mm" ;
    dct:description "Portable hemispherical RTI dome designed and built by Hüseyin Erdoğan (2021, revised 2024). Aluminium shell, 48-LED array across 6 elevation tiers (8 LEDs per tier, angular coverage ~9°–60°). Powered by a 5V portable power bank. Deployed at Rupe Magna in September 2025."@en ;
    rdfs:label "Custom-Built Portable RTI Dome"@en .

rm-equip:fujifilm-xs20
    rdf:type owl:NamedIndividual, chs:Hardware ;
    schema:brand "Fujifilm" ;
    schema:model "X-S20" ;
    dct:description "APS-C mirrorless camera body. Used with Fujifilm XF 16–55 mm f/2.8 R LM WR lens. Operated in manual exposure mode throughout all RTI acquisition sessions. Images processed with darktable 5.4.1 and exported as linear JPEG."@en ;
    rdfs:label "Fujifilm X-S20 Mirrorless Camera"@en .


# ---------------------------------------------------------------------------
# A.5 — MeasurementType definitions (7 types)
# ---------------------------------------------------------------------------

rm-mtype:iso
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "ISO sensitivity"@en .

rm-mtype:f-number
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "f-number (aperture)"@en .

rm-mtype:exposure-time
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "exposure time"@en .

rm-mtype:focal-length
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "focal length"@en .

rm-mtype:file-size
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "file size"@en .

rm-mtype:image-width
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "image width"@en .

rm-mtype:image-height
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "image height"@en .

# --- RTI processing types (used by the RTI provenance builder, defined once here, not per dataset) ---

rm-mtype:rti-nplanes
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "Number of RTI polynomial planes"@en .

rm-mtype:jpeg-quality
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "JPEG compression quality"@en .

rm-mtype:rti-basis-type
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "RTI basis type"@en .

rm-mtype:rti-web-layout
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "RTI web output layout"@en .

rm-mtype:rti-color-profile-mode
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "RTI colour profile mode"@en .

rm-mtype:rti-openlime
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "OpenLime web viewer enabled"@en .

rm-mtype:rti-crop-origin
    rdf:type owl:NamedIndividual, a-dd:MeasurementType ;
    rdfs:label "RTI output crop origin (x, y, angle)"@en .


# ---------------------------------------------------------------------------
# A.6 — MeasurementUnit definitions (6 units)
# ---------------------------------------------------------------------------

rm-unit:iso-sensitivity
    rdf:type owl:NamedIndividual, muapit:MeasurementUnit ;
    rdfs:label "ISO"@en .

rm-unit:f-stop
    rdf:type owl:NamedIndividual, muapit:MeasurementUnit ;
    rdfs:label "f-stop"@en .

rm-unit:second
    rdf:type owl:NamedIndividual, muapit:MeasurementUnit ;
    rdfs:label "second"@en .

rm-unit:millimetre
    rdf:type owl:NamedIndividual, muapit:MeasurementUnit ;
    rdfs:label "mm"@en .

rm-unit:megabyte
    rdf:type owl:NamedIndividual, muapit:MeasurementUnit ;
    rdfs:label "MegaByte"@en .

rm-unit:pixel
    rdf:type owl:NamedIndividual, muapit:MeasurementUnit ;
    rdfs:label "pixel"@en .


##############################################################################
#    PART 2 — Figures and DatasetSeries (one entry per figure)
##############################################################################

# ---------------------------------------------------------------------------
# F01 — Sector AA — The Praying Figure with Spiral
# Sessions: RTI-01 – RTI-10  (10 sessions)
# ---------------------------------------------------------------------------

rm-fig:F01
    rdf:type owl:NamedIndividual, arco:ArchaeologicalProperty ;
    arco:isPartOf rm-site:rupe-magna ;
    dct:identifier "F01" ;
    dct:description "Rock art figure in Sector AA at Rupe Magna Rock Art Site. Depicts a praying human figure with a spiral motif."@en ;
    rdfs:label "The Praying Figure with Spiral (F01) — Sector AA"@en .

rm-series:F01
    rdf:type owl:NamedIndividual, dcat:DatasetSeries ;
    dct:creator rm-agent:huseyin-erdogan ;
    dct:license <LICENSE_URL_PLACEHOLDER> ;
    dct:description "All RTI photographic datasets documenting figure F01 (The Praying Figure with Spiral), Sector AA, at Rupe Magna Rock Art Site, Grosio, Italy. 10 acquisition sessions."@en ;
    dct:title "F01 RTI Dataset Series — The Praying Figure with Spiral, Rupe Magna"@en .


