# RTI Acquisition Method
# ---------------------------------------------------------------------------

rm-method:rti
    rdf:type owl:NamedIndividual, chs:Method ;
    rdfs:label "Reflectance Transformation Imaging (RTI)"@en ;
    dct:description "Photographic RTI acquisition using a custom-built portable hemispherical dome (460 mm diameter, 48 LEDs, 6 tiers). Each session captures 48 sequential exposures under individually activated LEDs for Polynomial Texture Mapping (PTM) and Hemispherical Harmonics (HSH) model generation."@en .
