<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/rupemagna/ontology/rti#"
     xml:base="https://w3id.org/rupemagna/ontology/rti"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dct="http://purl.org/dc/terms/"
     xmlns:dcat="http://www.w3.org/ns/dcat#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:geo="http://www.w3.org/2003/01/geo/wgs84_pos#"
     xmlns:schema="https://schema.org/"
     xmlns:arco="https://w3id.org/arco/ontology/arco/"
     xmlns:a-cd="https://w3id.org/arco/ontology/context-description/"
     xmlns:a-dd="https://w3id.org/arco/ontology/denotative-description/"
     xmlns:core="https://w3id.org/arco/ontology/core/"
     xmlns:chs="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#"
     xmlns:muapit="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#"
     xmlns:roapit="http://www.ontologydesignpatterns.org/ont/ro/roapit.owl#"
     xmlns:tiapit="http://www.ontologydesignpatterns.org/ont/ti/tiapit.owl#">

    <!--
    =====================================================================
    rupemagna-rti-ontology.owl
    Rupe Magna RTI Knowledge Graph — Application Profile Ontology
    ODP-aligned version (semRTI-ODP)

    This ontology profiles the Cultural Heritage Survey ODP
    (CulturalHeritageSurvey.ttl) for the specific purpose of
    documenting RTI photographic surveys of archaeological rock art
    surfaces at Rupe Magna, Grosio, Italy.

    The full CHS-ODP hierarchy is respected:
      CulturalHeritageProject
        └─ chs:hasSurvey ──► CulturalHeritageSurvey
              ├─ chs:isSurveyOn ──► CulturalProperty (arco:ArchaeologicalProperty)
              ├─ chs:usesEquipmentConfiguration ──► EquipmentConfiguration
              │     └─ chs:usesEquipment ──► Hardware
              └─ chs:hasObservationCollection ──► ObservationCollection
                    └─ chs:hasMember ──► Observation
                          ├─ chs:hasFeatureOfInterest ──► FeatureOfInterest
                          └─ chs:hasResult ──► Result (a-cd:PhotographicDocumentation)

    Author  : Hüseyin Erdoğan (https://orcid.org/0000-0002-2965-0918)
    Site    : Rupe Magna Rock Art Site, Grosio, Lombardy, Italy
    License : CC BY 4.0 (https://creativecommons.org/licenses/by/4.0/)
    Version : 1.0
    =====================================================================
    -->


    <!-- =================================================================
         Ontology declaration
    ================================================================== -->

    <owl:Ontology rdf:about="https://w3id.org/rupemagna/ontology/rti">
        <owl:versionIRI rdf:resource="https://w3id.org/rupemagna/ontology/rti/1.0"/>

        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl"/>
        <owl:imports rdf:resource="https://w3id.org/arco/ontology/arco/"/>
        <owl:imports rdf:resource="https://w3id.org/arco/ontology/context-description/"/>
        <owl:imports rdf:resource="https://w3id.org/arco/ontology/denotative-description/"/>
        <owl:imports rdf:resource="https://w3id.org/arco/ontology/core/"/>
        <owl:imports rdf:resource="http://www.w3.org/ns/dcat#"/>
        <owl:imports rdf:resource="http://purl.org/dc/terms/"/>
        <owl:imports rdf:resource="http://xmlns.com/foaf/0.1/"/>
        <owl:imports rdf:resource="http://www.w3.org/2003/01/geo/wgs84_pos#"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/ont/ro/roapit.owl"/>
        <owl:imports rdf:resource="http://www.ontologydesignpatterns.org/ont/ti/tiapit.owl"/>

        <dct:title xml:lang="en">Rupe Magna RTI — Application Profile Ontology (ODP-aligned)</dct:title>
        <dct:description xml:lang="en">OWL application profile for the Rupe Magna RTI Knowledge Graph, built directly on the Cultural Heritage Survey Ontology Design Pattern (CulturalHeritageSurvey.ttl). Profiles classes and properties from the CHS-ODP, ArCo, DCAT 3, DCT, FOAF, GeoWGS84, MUAPIT, ROAPIT, and TIAPIT to represent RTI photographic survey data of the Rupe Magna rock art site (Grosio, Lombardy, Italy).</dct:description>
        <dct:creator rdf:resource="https://orcid.org/0000-0002-2965-0918"/>
        <dct:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-08</dct:created>
        <rdfs:label xml:lang="en">Rupe Magna RTI Application Profile Ontology</rdfs:label>
        <rdfs:comment xml:lang="en">This ontology does not define new classes or properties. It profiles the CHS-ODP and supporting ontologies (ArCo, DCAT, DCT, FOAF, GeoWGS84, MUAPIT, ROAPIT, TIAPIT) for RTI photographic surveys of Rupe Magna rock art surfaces. The key alignment bridge is: arco:ArchaeologicalProperty is declared a subclass of both chs:CulturalProperty and chs:FeatureOfInterest.</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>


    <!-- =================================================================
         Annotation properties
    ================================================================== -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/identifier"/>
    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/format"/>
    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/mbox"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/affiliation"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/jobTitle"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/identifier"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/brand"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/model"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/addressLocality"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/addressRegion"/>
    <owl:AnnotationProperty rdf:about="https://schema.org/addressCountry"/>
    <owl:AnnotationProperty rdf:about="https://w3id.org/arco/ontology/context-description/digitalFileName"/>
    <owl:AnnotationProperty rdf:about="https://w3id.org/arco/ontology/context-description/hasCaption"/>


    <!-- =================================================================
         Object Properties — CHS-ODP core chain
    ================================================================== -->

    <!-- chs:hasSurvey — Project → Survey -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasSurvey">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageProject"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey"/>
        <rdfs:label xml:lang="en">has survey</rdfs:label>
        <rdfs:comment xml:lang="en">Links the Rupe Magna RTI project (rm-project:rupe-magna-rti) to each of the 40 RTI acquisition sessions.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- chs:isSurveyOn — Survey → CulturalProperty (arco:ArchaeologicalProperty) -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#isSurveyOn">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:label xml:lang="en">is survey on</rdfs:label>
        <rdfs:comment xml:lang="en">Links the RTI survey to its archaeological subject. Each survey targets exactly two ArchaeologicalProperty instances: the specific rock art figure (rm-fig:FXX) and the overall site (rm-site:rupe-magna).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- chs:usesEquipmentConfiguration — Survey → EquipmentConfiguration -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#usesEquipmentConfiguration">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#EquipmentConfiguration"/>
        <rdfs:label xml:lang="en">uses equipment configuration</rdfs:label>
        <rdfs:comment xml:lang="en">Links the RTI survey to the EquipmentConfiguration recording the RTI dome, camera body, and exposure settings for that session.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- chs:usesEquipment — EquipmentConfiguration → Hardware -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#usesEquipment">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#EquipmentConfiguration"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Hardware"/>
        <rdfs:label xml:lang="en">uses equipment</rdfs:label>
        <rdfs:comment xml:lang="en">Each EquipmentConfiguration references exactly two Hardware items: the custom RTI dome (rm-equip:rti-dome) and the Fujifilm X-S20 camera body (rm-equip:fujifilm-xs20).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- chs:hasObservationCollection — Survey → ObservationCollection -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasObservationCollection">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#ObservationCollection"/>
        <rdfs:label xml:lang="en">has observation collection</rdfs:label>
        <rdfs:comment xml:lang="en">Each RTI session produces exactly one ObservationCollection of 48 Observations — one per LED position (6 elevation tiers × 8 azimuth positions).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- chs:hasMember — ObservationCollection → Observation -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasMember">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#ObservationCollection"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Observation"/>
        <rdfs:label xml:lang="en">has member</rdfs:label>
        <rdfs:comment xml:lang="en">Links an ObservationCollection to its 48 constituent Observations.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- chs:hasFeatureOfInterest — Observation → FeatureOfInterest (arco:ArchaeologicalProperty) -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasFeatureOfInterest">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Observation"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:label xml:lang="en">has feature of interest</rdfs:label>
        <rdfs:comment xml:lang="en">Links each Observation to the rock art figure it documents (rm-fig:FXX). All 48 observations in a session share the same feature of interest. Valid because arco:ArchaeologicalProperty is declared a subclass of chs:FeatureOfInterest.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- chs:hasResult — Observation → Result (a-cd:PhotographicDocumentation) -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasResult">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Observation"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Result"/>
        <rdfs:label xml:lang="en">has result</rdfs:label>
        <rdfs:comment xml:lang="en">Each Observation yields exactly two Results: a processed JPEG export (rm-photo:{basename}-jpg) and a Fujifilm RAF raw file (rm-photo:{basename}-raw). Both are typed as chs:Result and a-cd:PhotographicDocumentation.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- core:hasAgentRole — Survey → AgentRole -->
    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/core/hasAgentRole">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:label xml:lang="en">has agent role</rdfs:label>
        <rdfs:comment xml:lang="en">Links each survey to the AgentRole describing the photographer. Each session has exactly one AgentRole with roapit:withRole "Photographer".</rdfs:comment>
    </owl:ObjectProperty>

    <!-- roapit:isRoleOf — AgentRole → Person -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/ro/roapit.owl#isRoleOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:label xml:lang="en">is role of</rdfs:label>
        <rdfs:comment xml:lang="en">Links the AgentRole to rm-agent:huseyin-erdogan.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- a-dd:hasMeasurementCollection -->
    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection">
        <rdfs:label xml:lang="en">has measurement collection</rdfs:label>
        <rdfs:comment xml:lang="en">Used on EquipmentConfiguration (groups 4 camera exposure measurements) and on PhotographicDocumentation (groups per-image technical measurements).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- a-dd:hasMeasurement -->
    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/hasMeasurement">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <rdfs:label xml:lang="en">has measurement</rdfs:label>
    </owl:ObjectProperty>

    <!-- a-dd:measurementType -->
    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/denotative-description/measurementType">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementType"/>
        <rdfs:label xml:lang="en">measurement type</rdfs:label>
    </owl:ObjectProperty>

    <!-- muapit:hasMeasurementUnit -->
    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#hasMeasurementUnit">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#MeasurementUnit"/>
        <rdfs:label xml:lang="en">has measurement unit</rdfs:label>
    </owl:ObjectProperty>

    <!-- dct:creator -->
    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/creator">
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:label xml:lang="en">creator</rdfs:label>
        <rdfs:comment xml:lang="en">Always rm-agent:huseyin-erdogan. Applied to dcat:Dataset, dcat:DatasetSeries, chs:CulturalHeritageProject, and a-cd:PhotographicDocumentation.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- dct:license -->
    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/license">
        <rdfs:label xml:lang="en">license</rdfs:label>
        <rdfs:comment xml:lang="en">Always https://creativecommons.org/licenses/by/4.0/ (CC BY 4.0).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- dct:rights -->
    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/rights">
        <rdfs:label xml:lang="en">rights</rdfs:label>
        <rdfs:comment xml:lang="en">Applied to PhotographicDocumentation. Always CC BY 4.0.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- dct:spatial -->
    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/spatial">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:label xml:lang="en">spatial</rdfs:label>
        <rdfs:comment xml:lang="en">Links each RTI dataset to rm-site:rupe-magna.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- dct:isPartOf -->
    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/isPartOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicDocumentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:label xml:lang="en">is part of</rdfs:label>
        <rdfs:comment xml:lang="en">Links each PhotographicDocumentation to its dcat:Distribution. JPEG → -jpg distribution; RAF → -raw distribution.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- dcat:distribution -->
    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#distribution">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:label xml:lang="en">distribution</rdfs:label>
        <rdfs:comment xml:lang="en">Each RTI dataset has at least 2 distributions: JPEG export (-jpg) and RAF raw (-raw). Sessions with RTI output have a third (-ptm/-hsh/-bilinear).</rdfs:comment>
    </owl:ObjectProperty>

    <!-- dcat:inSeries -->
    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#inSeries">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#DatasetSeries"/>
        <rdfs:label xml:lang="en">in series</rdfs:label>
    </owl:ObjectProperty>

    <!-- dcat:seriesMember -->
    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/dcat#seriesMember">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#DatasetSeries"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:label xml:lang="en">series member</rdfs:label>
    </owl:ObjectProperty>

    <!-- arco:isPartOf — figure → site -->
    <owl:ObjectProperty rdf:about="https://w3id.org/arco/ontology/arco/isPartOf">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:label xml:lang="en">is part of</rdfs:label>
        <rdfs:comment xml:lang="en">Links each rock art figure (rm-fig:F01–F11) to rm-site:rupe-magna.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- schema:identifier (ORCID) -->
    <owl:ObjectProperty rdf:about="https://schema.org/identifier">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
        <rdfs:comment xml:lang="en">Links rm-agent:huseyin-erdogan to his ORCID URI.</rdfs:comment>
    </owl:ObjectProperty>


    <!-- =================================================================
         Datatype Properties
    ================================================================== -->

    <owl:DatatypeProperty rdf:about="http://www.ontologydesignpatterns.org/ont/ti/tiapit.owl#startTime">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">start time</rdfs:label>
        <rdfs:comment xml:lang="en">Start date of the RTI acquisition session (xsd:date).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.ontologydesignpatterns.org/ont/ti/tiapit.owl#endTime">
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">end time</rdfs:label>
        <rdfs:comment xml:lang="en">End date of the RTI acquisition session (xsd:date).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.ontologydesignpatterns.org/ont/ro/roapit.owl#withRole">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">with role</rdfs:label>
        <rdfs:comment xml:lang="en">Always the literal "Photographer".</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#value">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/denotative-description/Measurement"/>
        <rdfs:label xml:lang="en">value</rdfs:label>
        <rdfs:comment xml:lang="en">Numeric measurement value. xsd:integer for ISO, file-size, image-width, image-height; xsd:decimal for aperture, exposure-time, focal-length.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/created">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicDocumentation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">created</rdfs:label>
        <rdfs:comment xml:lang="en">EXIF CreateDate converted to xsd:dateTime.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/issued">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">issued</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:label xml:lang="en">identifier</rdfs:label>
        <rdfs:comment xml:lang="en">Human-readable local ID. On dcat:Dataset: session code (e.g. "RTI-09"). On arco:ArchaeologicalProperty: figure code (e.g. "F01").</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/format">
        <rdfs:label xml:lang="en">format</rdfs:label>
        <rdfs:comment xml:lang="en">MIME type string: "image/jpeg", "image/x-fujifilm-raf", "image/x-ptm".</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/numberOfItems">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">number of items</rdfs:label>
        <rdfs:comment xml:lang="en">Always 48 for JPEG and RAF distributions. PTM distributions contain 1 file.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#lat">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">latitude</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#long">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">longitude</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#alt">
        <rdfs:domain rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">altitude</rdfs:label>
    </owl:DatatypeProperty>


    <!-- =================================================================
         Classes — ODP hierarchy with application-specific documentation
    ================================================================== -->

    <!--
        KEY ALIGNMENT BRIDGE
        arco:ArchaeologicalProperty is used wherever the ODP expects
        chs:CulturalProperty (site/figure level) and chs:FeatureOfInterest
        (observation target). These two subClassOf declarations make the
        application profile OWL-valid.
    -->
    <owl:Class rdf:about="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalProperty"/>
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#FeatureOfInterest"/>
        <rdfs:label xml:lang="en">Archaeological Property</rdfs:label>
        <rdfs:comment xml:lang="en">Used at two levels: (1) the overall site (rm-site:rupe-magna); (2) individual rock art figures (rm-fig:F01–F11). Figures are linked to the site via arco:isPartOf. Declared subclass of both chs:CulturalProperty and chs:FeatureOfInterest to satisfy ODP range constraints.</rdfs:comment>
    </owl:Class>

    <!-- chs:CulturalHeritageProject — top-level container -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageProject">
        <rdfs:label xml:lang="en">Cultural Heritage Project</rdfs:label>
        <rdfs:comment xml:lang="en">The top-level research project. One instance: rm-project:rupe-magna-rti, grouping all 40 RTI acquisition sessions at Rupe Magna via chs:hasSurvey.</rdfs:comment>
    </owl:Class>

    <!-- chs:CulturalHeritageSurvey -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#CulturalHeritageSurvey">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#usesEquipmentConfiguration"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#EquipmentConfiguration"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasObservationCollection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#ObservationCollection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#isSurveyOn"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/core/hasAgentRole"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/core/AgentRole"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Cultural Heritage Survey (RTI)</rdfs:label>
        <rdfs:comment xml:lang="en">One RTI photographic survey session. URI pattern: rm-survey:{sessionID}. Carries tiapit:startTime / tiapit:endTime (xsd:date), links to EquipmentConfiguration, ObservationCollection, AgentRole, and both the target figure and the site via chs:isSurveyOn.</rdfs:comment>
    </owl:Class>

    <!-- chs:EquipmentConfiguration -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#EquipmentConfiguration">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#usesEquipment"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Hardware"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/hasMeasurementCollection"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Equipment Configuration</rdfs:label>
        <rdfs:comment xml:lang="en">Records hardware and camera exposure settings for one RTI session. URI pattern: rm-econf:{sessionID}. Two Hardware items (dome + camera) and one MeasurementCollection grouping ISO, aperture, shutter speed, focal length.</rdfs:comment>
    </owl:Class>

    <!-- chs:Hardware -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Hardware">
        <rdfs:label xml:lang="en">Hardware</rdfs:label>
        <rdfs:comment xml:lang="en">Two shared instances: rm-equip:rti-dome (custom hemispherical dome, 460 mm, 48 LEDs, 6 tiers) and rm-equip:fujifilm-xs20 (APS-C mirrorless camera with XF 16–55 mm f/2.8 lens).</rdfs:comment>
    </owl:Class>

    <!-- chs:ObservationCollection -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#ObservationCollection">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasMember"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">48</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Observation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Observation Collection</rdfs:label>
        <rdfs:comment xml:lang="en">Contains exactly 48 Observations for one RTI session. URI pattern: rm-ocoll:{sessionID}.</rdfs:comment>
    </owl:Class>

    <!-- chs:Observation -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Observation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasFeatureOfInterest"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/arco/ArchaeologicalProperty"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#hasResult"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/context-description/PhotographicDocumentation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Observation (single LED exposure)</rdfs:label>
        <rdfs:comment xml:lang="en">One camera exposure under a single LED. URI pattern: rm-obs:{basename}. Two Results: processed JPEG export and RAF raw file.</rdfs:comment>
    </owl:Class>

    <!-- chs:Result -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Result">
        <rdfs:label xml:lang="en">Result</rdfs:label>
        <rdfs:comment xml:lang="en">Co-type on every PhotographicDocumentation, marking it as the output of a survey Observation.</rdfs:comment>
    </owl:Class>

    <!-- a-cd:PhotographicDocumentation — subclass of chs:Result -->
    <owl:Class rdf:about="https://w3id.org/arco/ontology/context-description/PhotographicDocumentation">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#Result"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/dc/terms/creator"/>
                <owl:hasValue rdf:resource="https://w3id.org/rupemagna/resource/agent/huseyin-erdogan"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/dc/terms/rights"/>
                <owl:hasValue rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/dc/terms/isPartOf"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Photographic Documentation</rdfs:label>
        <rdfs:comment xml:lang="en">A single photograph file. URI patterns: rm-photo:{basename}-jpg (JPEG export) and rm-photo:{basename}-raw (RAF raw). Carries dct:created, dct:format, a-cd:digitalFileName, a-cd:hasCaption, and links to its distribution and measurement collection.</rdfs:comment>
    </owl:Class>

    <!-- dcat:Dataset -->
    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Dataset">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/dc/terms/creator"/>
                <owl:hasValue rdf:resource="https://w3id.org/rupemagna/resource/agent/huseyin-erdogan"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/dc/terms/license"/>
                <owl:hasValue rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/dcat#distribution"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Dataset</rdfs:label>
        <rdfs:comment xml:lang="en">One RTI acquisition session. URI pattern: rm-data:{sessionID}.</rdfs:comment>
    </owl:Class>

    <!-- dcat:DatasetSeries -->
    <owl:Class rdf:about="http://www.w3.org/ns/dcat#DatasetSeries">
        <rdfs:label xml:lang="en">Dataset Series</rdfs:label>
        <rdfs:comment xml:lang="en">Groups all RTI datasets for one rock art figure. URI pattern: rm-series:{figureID}. 11 series total (F01–F11).</rdfs:comment>
    </owl:Class>

    <!-- dcat:Distribution -->
    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Distribution">
        <rdfs:label xml:lang="en">Distribution</rdfs:label>
        <rdfs:comment xml:lang="en">A concrete file set. Three types: JPEG export (-jpg, 48 files), RAF raw (-raw, 48 files), RTI output (-ptm/-hsh/-bilinear, 1 file). URI pattern: rm-dist:{sessionID}-{type}.</rdfs:comment>
    </owl:Class>

    <!-- core:AgentRole -->
    <owl:Class rdf:about="https://w3id.org/arco/ontology/core/AgentRole">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/ro/roapit.owl#isRoleOf"/>
                <owl:hasValue rdf:resource="https://w3id.org/rupemagna/resource/agent/huseyin-erdogan"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Agent Role</rdfs:label>
        <rdfs:comment xml:lang="en">URI pattern: rm-role:{sessionID}-photographer. Always: isRoleOf → rm-agent:huseyin-erdogan; withRole → "Photographer".</rdfs:comment>
    </owl:Class>

    <!-- foaf:Person -->
    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person">
        <rdfs:label xml:lang="en">Person</rdfs:label>
        <rdfs:comment xml:lang="en">One shared individual: rm-agent:huseyin-erdogan (foaf:Person + core:Agent).</rdfs:comment>
    </owl:Class>

    <!-- a-dd:MeasurementCollection -->
    <owl:Class rdf:about="https://w3id.org/arco/ontology/denotative-description/MeasurementCollection">
        <rdfs:label xml:lang="en">Measurement Collection</rdfs:label>
        <rdfs:comment xml:lang="en">Session-level: groups 4 camera exposure measurements (ISO, aperture, shutter, focal length). Image-level: groups 3 measurements for JPEG (file size, width, height) or 2 for RAF (width, height).</rdfs:comment>
    </owl:Class>

    <!-- a-dd:Measurement -->
    <owl:Class rdf:about="https://w3id.org/arco/ontology/denotative-description/Measurement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/arco/ontology/denotative-description/measurementType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/arco/ontology/denotative-description/MeasurementType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#hasMeasurementUnit"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#MeasurementUnit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Measurement</rdfs:label>
        <rdfs:comment xml:lang="en">One quantitative measurement with type, unit, and value. URI pattern: rm-meas:{sessionID}-{type} for session-level; rm-meas:{basename}-{format}-{type} for image-level.</rdfs:comment>
    </owl:Class>

    <!-- a-dd:MeasurementType -->
    <owl:Class rdf:about="https://w3id.org/arco/ontology/denotative-description/MeasurementType">
        <rdfs:label xml:lang="en">Measurement Type</rdfs:label>
        <rdfs:comment xml:lang="en">7 types: rm-mtype:iso, rm-mtype:f-number, rm-mtype:exposure-time, rm-mtype:focal-length, rm-mtype:file-size, rm-mtype:image-width, rm-mtype:image-height.</rdfs:comment>
    </owl:Class>

    <!-- muapit:MeasurementUnit -->
    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#MeasurementUnit">
        <rdfs:label xml:lang="en">Measurement Unit</rdfs:label>
        <rdfs:comment xml:lang="en">6 units: rm-unit:iso-sensitivity, rm-unit:f-stop, rm-unit:second, rm-unit:millimetre, rm-unit:megabyte, rm-unit:pixel.</rdfs:comment>
    </owl:Class>

</rdf:RDF>
