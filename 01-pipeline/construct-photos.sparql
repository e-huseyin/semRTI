##############################################################################
# construct-photos.sparql  (semRTI-ODP)
# SPARQL Anything — Section D: per-photo resources
#
# ODP alignment (CulturalHeritageSurvey.ttl):
#
#   chs:ObservationCollection
#     └─ chs:hasMember ──► chs:Observation
#           ├─ chs:hasFeatureOfInterest ──► arco:ArchaeologicalProperty
#           └─ chs:hasResult ──► chs:Result (a-cd:PhotographicDocumentation)
#
# Generates for every JPG in exif-metadata.json:
#   rm-obs:{basename}           chs:Observation
#   rm-photo:{basename}-jpg     chs:Result, a-cd:PhotographicDocumentation
#   rm-mcoll:{basename}-jpg     a-dd:MeasurementCollection  (filesize + w + h)
#   rm-meas:{basename}-jpg-*    a-dd:Measurement  × 3
#
# Additionally, when the source is a jpg-export* directory (RAW+Fast Forge):
#   rm-photo:{basename}-raw     chs:Result, a-cd:PhotographicDocumentation
#   rm-mcoll:{basename}-raw     a-dd:MeasurementCollection  (w + h only)
#   rm-meas:{basename}-raw-*    a-dd:Measurement  × 2
#
# Also adds:
#   rm-ocoll:{sessionID}  chs:hasMember  rm-obs:{basename}
#
# FILTER covers all jpg-export* variants (jpg-export/, jpg-export-linear/,
# jpg-export-linear-LC/, etc.) AND jpg/ for datasets captured as JPEG-only
# (no RAW, no Fast Forge). When both directories exist for the same session,
# jpg-export* takes priority and jpg/ entries are skipped.
# Camera JPEG files in jpg/ for RAW+Fast Forge sessions are excluded.
#
# INPUT
#   EXIF_LOCATION_PLACEHOLDER — replaced by semRTI.py with file:// URI
##############################################################################

PREFIX fx:     <http://sparql.xyz/facade-x/ns/>
PREFIX xyz:    <http://sparql.xyz/facade-x/data/>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX dct:    <http://purl.org/dc/terms/>
PREFIX a-cd:   <https://w3id.org/arco/ontology/context-description/>
PREFIX a-dd:   <https://w3id.org/arco/ontology/denotative-description/>
PREFIX chs:    <http://www.ontologydesignpatterns.org/cp/owl/culturalheritagesurvey.owl#>
PREFIX muapit: <http://www.ontologydesignpatterns.org/ont/dul/muapit.owl#>

PREFIX rm-obs:   <https://w3id.org/rupemagna/resource/observation/>
PREFIX rm-photo: <https://w3id.org/rupemagna/resource/photo/>
PREFIX rm-mcoll: <https://w3id.org/rupemagna/resource/measurement-collection/>
PREFIX rm-meas:  <https://w3id.org/rupemagna/resource/measurement/>
PREFIX rm-ocoll: <https://w3id.org/rupemagna/resource/observation-collection/>
PREFIX rm-fig:   <https://w3id.org/rupemagna/resource/figure/>
PREFIX rm-dist:  <https://w3id.org/rupemagna/resource/distribution/>
PREFIX rm-agent: <https://w3id.org/rupemagna/resource/agent/>
PREFIX rm-mtype:  <https://w3id.org/rupemagna/resource/measurement-type/>
PREFIX rm-unit:   <https://w3id.org/rupemagna/resource/unit/>
PREFIX rm-method: <https://w3id.org/rupemagna/resource/method/>

CONSTRUCT {

  ### Link ObservationCollection → Observation  [chs:hasMember + inverse] ###
  ?ocollURI chs:hasMember ?obsURI .
  ?obsURI chs:isMemberOf ?ocollURI .

  ### Observation  [chs:Observation] ###
  ?obsURI
    a owl:NamedIndividual, chs:Observation ;
    chs:hasFeatureOfInterest ?figURI ;
    chs:hasResult ?photoJpgURI, ?photoRawURI ;
    chs:usesMethod rm-method:rti ;
    rdfs:label ?obsLabel .

  ### Photo JPG  [chs:Result + a-cd:PhotographicDocumentation] ###
  ?photoJpgURI
    a owl:NamedIndividual, chs:Result, a-cd:PhotographicDocumentation ;
    dct:creator rm-agent:huseyin-erdogan ;
    dct:isPartOf ?distJpgURI ;
    dct:rights <https://creativecommons.org/licenses/by/4.0/> ;
    a-dd:hasMeasurementCollection ?mcollJpgURI ;
    dct:created ?createDateTime ;
    dct:format "image/jpeg" ;
    a-cd:digitalFileName ?fileNameJpg ;
    a-cd:hasCaption ?caption ;
    rdfs:label ?labelJpg .

  ### Photo RAW  [only for jpg-export* sessions — unbound when jpg-only] ###
  ?photoRawURI
    a owl:NamedIndividual, chs:Result, a-cd:PhotographicDocumentation ;
    dct:creator rm-agent:huseyin-erdogan ;
    dct:isPartOf ?distRawURI ;
    dct:rights <https://creativecommons.org/licenses/by/4.0/> ;
    a-dd:hasMeasurementCollection ?mcollRawURI ;
    dct:created ?createDateTime ;
    dct:format "image/x-fujifilm-raf" ;
    a-cd:digitalFileName ?fileNameRaw ;
    a-cd:hasCaption ?caption ;
    rdfs:label ?labelRaw .

  ### MeasurementCollection JPG (filesize + width + height) ###
  ?mcollJpgURI
    a owl:NamedIndividual, a-dd:MeasurementCollection ;
    a-dd:hasMeasurement ?measFilesizeURI, ?measWidthJpgURI, ?measHeightJpgURI .

  ?measFilesizeURI
    a owl:NamedIndividual, a-dd:Measurement ;
    a-dd:measurementType rm-mtype:file-size ;
    muapit:hasMeasurementUnit rm-unit:megabyte ;
    muapit:value ?fileSize ;
    rdfs:label ?labelFilesize .

  ?measWidthJpgURI
    a owl:NamedIndividual, a-dd:Measurement ;
    a-dd:measurementType rm-mtype:image-width ;
    muapit:hasMeasurementUnit rm-unit:pixel ;
    muapit:value ?imageWidth ;
    rdfs:label ?labelWidthJpg .

  ?measHeightJpgURI
    a owl:NamedIndividual, a-dd:Measurement ;
    a-dd:measurementType rm-mtype:image-height ;
    muapit:hasMeasurementUnit rm-unit:pixel ;
    muapit:value ?imageHeight ;
    rdfs:label ?labelHeightJpg .

  ### MeasurementCollection RAW (only for jpg-export* sessions) ###
  ?mcollRawURI
    a owl:NamedIndividual, a-dd:MeasurementCollection ;
    a-dd:hasMeasurement ?measWidthRawURI, ?measHeightRawURI .

  ?measWidthRawURI
    a owl:NamedIndividual, a-dd:Measurement ;
    a-dd:measurementType rm-mtype:image-width ;
    muapit:hasMeasurementUnit rm-unit:pixel ;
    muapit:value ?imageWidth ;
    rdfs:label ?labelWidthRaw .

  ?measHeightRawURI
    a owl:NamedIndividual, a-dd:Measurement ;
    a-dd:measurementType rm-mtype:image-height ;
    muapit:hasMeasurementUnit rm-unit:pixel ;
    muapit:value ?imageHeight ;
    rdfs:label ?labelHeightRaw .

}
WHERE {

  ##########################################################################
  # Read EXIF JSON — iterate all array elements
  ##########################################################################
  SERVICE <x-sparql-anything:EXIF_LOCATION_PLACEHOLDER> {
    ?root a fx:root ;
          ?idx ?exifItem .
    ?exifItem
      xyz:SourceFile  ?sourcePath ;
      xyz:FileName    ?fileName ;
      xyz:CreateDate  ?createDateRaw ;
      xyz:FileSize    ?fileSizeRaw ;
      xyz:ImageWidth  ?imageWidth ;
      xyz:ImageHeight ?imageHeight .
  }

  # Accept processed JPEG exports (all jpg-export* variants) AND camera JPEGs
  # (jpg/) for sessions captured without RAW files / Fast Forge.
  FILTER(REGEX(?sourcePath, "/(jpg-export[^/]*|jpg)/"))
  FILTER(REGEX(?fileName, "\\.[Jj][Pp][Gg]$"))

  ##########################################################################
  # Extract identifiers from path
  # Pattern: .../[figureID]/[sessionID]/(jpg-export*|jpg)/[file.jpg]
  ##########################################################################
  BIND(REPLACE(?sourcePath,
       ".*/([^/]+)/([^/]+)/(jpg-export[^/]*|jpg)/.*", "$1") AS ?figureID)
  BIND(REPLACE(?sourcePath,
       ".*/([^/]+)/([^/]+)/(jpg-export[^/]*|jpg)/.*", "$2") AS ?sessionID)
  BIND(REPLACE(?fileName, "\\.[Jj][Pp][Gg]$", "") AS ?basename)

  # Flag: true when file comes from a jpg-export* directory.
  BIND(REGEX(?sourcePath, "/jpg-export[^/]*/") AS ?isExport)

  # Priority: skip jpg/ entries for sessions that also have a jpg-export*
  # directory. Prevents duplicate triples when both exist.
  FILTER(
    ?isExport
    || NOT EXISTS {
      SERVICE <x-sparql-anything:EXIF_LOCATION_PLACEHOLDER> {
        ?root2 a fx:root ; ?idx2 ?checkItem .
        ?checkItem xyz:SourceFile ?checkPath .
      }
      FILTER(REGEX(?checkPath, "/jpg-export[^/]*/"))
      FILTER(CONTAINS(?checkPath, CONCAT("/", ?sessionID, "/")))
    }
  )

  ##########################################################################
  # Transform CreateDate: "2025:09:05 12:52:05" → xsd:dateTime
  ##########################################################################
  BIND(REPLACE(?createDateRaw,
       "^(\\d{4}):(\\d{2}):(\\d{2}) (\\d{2}:\\d{2}:\\d{2})$",
       "$1-$2-$3T$4") AS ?createDateStr)
  BIND(xsd:dateTime(?createDateStr) AS ?createDateTime)

  ##########################################################################
  # Transform FileSize: "23 MB" → xsd:integer 23
  ##########################################################################
  BIND(xsd:integer(STRBEFORE(?fileSizeRaw, " MB")) AS ?fileSize)

  ##########################################################################
  # Construct URIs
  # Raw-companion URIs are UNDEF when ?isExport is false (jpg-only session),
  # so CONSTRUCT silently omits those triples.
  ##########################################################################
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/observation/",
       ?basename)) AS ?obsURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/photo/",
       ?basename, "-jpg")) AS ?photoJpgURI)
  BIND(IF(?isExport,
       IRI(CONCAT("https://w3id.org/rupemagna/resource/photo/",
       ?basename, "-raw")), ?_undef) AS ?photoRawURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/measurement-collection/",
       ?basename, "-jpg")) AS ?mcollJpgURI)
  BIND(IF(?isExport,
       IRI(CONCAT("https://w3id.org/rupemagna/resource/measurement-collection/",
       ?basename, "-raw")), ?_undef) AS ?mcollRawURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/measurement/",
       ?basename, "-jpg-filesize")) AS ?measFilesizeURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/measurement/",
       ?basename, "-jpg-width")) AS ?measWidthJpgURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/measurement/",
       ?basename, "-jpg-height")) AS ?measHeightJpgURI)
  BIND(IF(?isExport,
       IRI(CONCAT("https://w3id.org/rupemagna/resource/measurement/",
       ?basename, "-raw-width")), ?_undef) AS ?measWidthRawURI)
  BIND(IF(?isExport,
       IRI(CONCAT("https://w3id.org/rupemagna/resource/measurement/",
       ?basename, "-raw-height")), ?_undef) AS ?measHeightRawURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/observation-collection/",
       ?sessionID)) AS ?ocollURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/figure/",
       ?figureID)) AS ?figURI)
  BIND(IRI(CONCAT("https://w3id.org/rupemagna/resource/distribution/",
       ?sessionID, "-jpg")) AS ?distJpgURI)
  BIND(IF(?isExport,
       IRI(CONCAT("https://w3id.org/rupemagna/resource/distribution/",
       ?sessionID, "-raw")), ?_undef) AS ?distRawURI)

  ##########################################################################
  # File names
  ##########################################################################
  BIND(?fileName AS ?fileNameJpg)
  BIND(IF(?isExport, CONCAT(?basename, ".RAF"), ?_undef) AS ?fileNameRaw)

  ##########################################################################
  # Labels
  ##########################################################################
  BIND(STRLANG(CONCAT(
       "Observation — ", ?basename, ", ", ?figureID, ", ", ?sessionID),
       "en") AS ?obsLabel)
  BIND(STRLANG(CONCAT(
       ?basename, " — ", ?figureID, ", ", ?sessionID, ", Rupe Magna (JPEG)"),
       "en") AS ?labelJpg)
  BIND(IF(?isExport,
       STRLANG(CONCAT(
       ?basename, " — ", ?figureID, ", ", ?sessionID, ", Rupe Magna (RAF)"),
       "en"), ?_undef) AS ?labelRaw)
  BIND(STRLANG(CONCAT(
       "Rupe Magna - [", ?figureID, "] - [", ?sessionID, "]"),
       "en") AS ?caption)
  BIND(STRLANG(CONCAT("File size — ", ?fileName),
       "en") AS ?labelFilesize)
  BIND(STRLANG(CONCAT("Image width — ", ?fileName),
       "en") AS ?labelWidthJpg)
  BIND(STRLANG(CONCAT("Image height — ", ?fileName),
       "en") AS ?labelHeightJpg)
  BIND(IF(?isExport,
       STRLANG(CONCAT("Image width — ", ?basename, ".RAF"), "en"),
       ?_undef) AS ?labelWidthRaw)
  BIND(IF(?isExport,
       STRLANG(CONCAT("Image height — ", ?basename, ".RAF"), "en"),
       ?_undef) AS ?labelHeightRaw)
}
